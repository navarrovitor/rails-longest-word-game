<h1>Games#new</h1>
<p>Find me in app/views/games/new.html.erb</p>
<div> <%= @letters %> </div>
<form action="/score" method="post">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <h1>What is the longest word you can think of?</h1>
  <input type="text" name="guess" placeholder="Guess something">
  <input type="submit" id="input">
  <%= hidden_field_tag :grid, @letters%>
</form>
